# ServerHub Environment Configuration
# Copy this file to .env and edit before running docker-compose

# ── Authentication ─────────────────────────────────────
# Change these before deploying!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=serverhub-change-this-secret-in-production

# ── Network ────────────────────────────────────────────
# If running behind a reverse proxy or accessing from another machine,
# set this to the public IP/hostname of your server:
# NEXT_PUBLIC_API_URL=http://your-server-ip:8000
